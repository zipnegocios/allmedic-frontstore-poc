# =============================================================================
# AllMedic Frontstore — Variables de entorno (desarrollo local)
# =============================================================================
# Copia este archivo como .env.local y completa los valores reales.
# ⚠️  NUNCA subas .env / .env.local con valores reales a Git.
# =============================================================================

# ─── Base de datos (PostgreSQL vía Drizzle) ───
DATABASE_URL=postgresql://usuario:password@localhost:5432/allmedic
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=

# ─── NextAuth.js v5 ───
AUTH_SECRET=
AUTH_TRUST_HOST=true
AUTH_URL=

# ─── WhatsApp (checkout público) ───
NEXT_PUBLIC_WHATSAPP_NUMBER=13164695701
VITE_WHATSAPP_NUMBER=13164695701

# ─── OpenAI (embeddings / RAG) ───
OPENAI_API_KEY=

# ─── Instagram Graph API (omnichannel, opcional) ───
IG_APP_SECRET=
IG_VERIFY_TOKEN=
IG_ACCESS_TOKEN=
IG_PAGE_ID=

# ─── WhatsApp Web Service (backend de WA, opcional) ───
WA_WEBHOOK_URL=
WA_SERVICE_URL=

# ─── Cloudflare R2 — Media Library (bucket general) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=
NEXT_PUBLIC_R2_PUBLIC_URL=

# ─── Cloudflare R2 — Cotizaciones (bucket dedicado, separado de Media Library) ───
# Bucket "cotizaciones" ya creado en Cloudflare (WNAM). Las credenciales R2_ACCESS_KEY_ID/
# R2_SECRET_ACCESS_KEY de arriba ya tienen alcance sobre este bucket (verificado en Fase 0
# de ejecución) — no se requieren credenciales dedicadas.
R2_QUOTES_BUCKET=cotizaciones
R2_QUOTES_PUBLIC_URL=https://cotizaciones.allmedicuniforms.com

# ─── Resend — Correo transaccional ───
RESEND_API_KEY=
SALES_TEAM_EMAIL=allmedicuniforms@gmail.com
