# =============================================================================
# AllMedic Frontstore — Variables de Entorno para EasyPanel
# =============================================================================
# Copia este archivo como .env en tu servidor o pega las variables
# directamente en el panel de EasyPanel → Environment Variables.
#
# ⚠️  NUNCA subas este archivo con valores reales a Git.
# ⚠️  Añade .env a .gitignore
# =============================================================================

# ═════════════════════════════════════════════════════════════════════════════
# SECCIÓN 1: BASE DE DATOS — PostgreSQL (EasyPanel Service)
# ═════════════════════════════════════════════════════════════════════════════

# ─── Conexión interna (entre contenedores de EasyPanel, misma red Docker) ───
# Cuando la app y la DB están en el mismo servidor EasyPanel,
# usan el nombre del servicio como host (DNS interno de Docker).
DB_USER=amuUser
DB_PASSWORD=TU_PASSWORD_AQUI
DB_HOST=postgres                    # ← nombre del servicio en EasyPanel
DB_PORT=5432                        # ← puerto interno del contenedor PostgreSQL
DB_NAME=amuData

# ─── URL de conexión interna (construida automáticamente por la app) ───
# La app construye esta URL desde DB_USER, DB_PASSWORD, DB_HOST, DB_PORT, DB_NAME
# No necesitas setearla manualmente a menos que quieras sobreescribir.
# DATABASE_URL=postgresql://amuUser:TU_PASSWORD_AQUI@postgres:5432/amuData?sslmode=disable

# ─── Conexión externa (para acceso remoto / desarrollo local) ───
# Usa esta URL cuando conectas desde fuera del servidor (ej: tu laptop)
# Reemplaza 31.220.56.1 y 5435 con los valores reales de tu servidor.
# DATABASE_URL_EXTERNAL=postgresql://amuUser:TU_PASSWORD_AQUI@31.220.56.1:5435/amuData?sslmode=disable

# ═════════════════════════════════════════════════════════════════════════════
# SECCIÓN 2: AUTENTICACIÓN — NextAuth.js v5
# ═════════════════════════════════════════════════════════════════════════════

# Clave secreta para firmar JWTs y cookies (mínimo 32 caracteres)
# Genera una con:  openssl rand -base64 32
AUTH_SECRET=TU_AUTH_SECRET_AQUI_MINIMO_32_CARACTERES

# Trust host — necesario para NextAuth en contenedores Docker
AUTH_TRUST_HOST=true

# URL pública de la app (EasyPanel genera esta automáticamente)
# Solo necesario si usas callbacks OAuth. Para credentials basta con AUTH_TRUST_HOST.
# AUTH_URL=https://allmedic.tu-dominio.com

# ═════════════════════════════════════════════════════════════════════════════
# SECCIÓN 3: WHATSAPP — Número de contacto
# ═════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_WHATSAPP_NUMBER=13164695701
VITE_WHATSAPP_NUMBER=13164695701

# ═════════════════════════════════════════════════════════════════════════════
# SECCIÓN 4: OPENAI — Embeddings / RAG (opcional)
# ═════════════════════════════════════════════════════════════════════════════

OPENAI_API_KEY=sk-tu-openai-key-aqui

# ═════════════════════════════════════════════════════════════════════════════
# SECCIÓN 5: INSTAGRAM GRAPH API — Omnichannel (opcional)
# ═════════════════════════════════════════════════════════════════════════════

IG_APP_SECRET=tu-app-secret-de-instagram
IG_VERIFY_TOKEN=tu-verify-token-minimo-32-chars
IG_ACCESS_TOKEN=tu-access-token-de-instagram
IG_PAGE_ID=tu-page-id

# ═════════════════════════════════════════════════════════════════════════════
# SECCIÓN 6: WHATSAPP WEB SERVICE — Backend de WA (opcional)
# ═════════════════════════════════════════════════════════════════════════════

WA_WEBHOOK_URL=https://wa-service.tu-dominio.com
WA_SERVICE_URL=https://wa-service.tu-dominio.com

# ═════════════════════════════════════════════════════════════════════════════
# SECCIÓN 7: CONFIGURACIÓN DE LA APP
# ═════════════════════════════════════════════════════════════════════════════

# Entorno
NODE_ENV=production

# Puerto interno del contenedor (no cambiar a menos que modifiques el Dockerfile)
PORT=3000

# Forzar uso de datos dummy si la DB no responde (útil para testing)
FORCE_DUMMY_DATA=false
